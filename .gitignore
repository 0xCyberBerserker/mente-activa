# Godot 4+ specific ignores
.godot/
.import/
/android/

# Local agent/tool state
.agents/
.codex/

# Local config and secrets
.env
.env.*
!.env.example
local.properties
*.jks
*.keystore
*.p12
*.pem
*.key
*.idsig
*.log

# --- Build and release outputs ---
build/
bin/
dist/
ejecutar/
*.apk
*.exe
*.dll
*.so
*.pck
*.wasm
*.x86_64
*.arm64
*.zip
*.sha256

# Vendored Orchestrator extension binaries are source dependencies for this project.
!addons/orchestrator/**/*.dll
!addons/orchestrator/**/*.dylib
!addons/orchestrator/**/*.exp
!addons/orchestrator/**/*.lib
!addons/orchestrator/**/*.so
!addons/orchestrator/**/*.wasm
