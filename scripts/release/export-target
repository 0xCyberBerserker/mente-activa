#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/common.sh"

target="${1:?missing release target}"

cd "$repo_root"
require_commands godot jq zip python3

version="$(json_get '.version')"
base_name="$(json_get '.artifactBaseName')"
preset="$(target_json_get "$target" '.preset')"
platform="$(target_json_get "$target" '.platform')"
architecture="$(target_json_get "$target" '.architecture')"
target_templates_dir="$(templates_dir)"
workspace="$(release_workspace)"
export_dir="$workspace/exports/$target"
package_parent="$workspace/packages/$target"
assets_dir="$workspace/assets/$target"

clean_dir "$export_dir"
clean_dir "$package_parent"
clean_dir "$assets_dir"

case "$target" in
  linux-x86_64)
    test -f "$target_templates_dir/linux_release.x86_64"
    primary_asset="${base_name}-${version}.x86_64"
    bundle_name="${base_name}-${version}-linux-x86_64"
    ;;
  linux-arm64)
    test -f "$target_templates_dir/linux_release.arm64"
    primary_asset="${base_name}-${version}.arm64"
    bundle_name="${base_name}-${version}-linux-arm64"
    ;;
  windows-x86_64)
    primary_asset="${base_name}-${version}.exe"
    bundle_name="${base_name}-${version}-windows-x86_64"
    ;;
  android-arm64)
    primary_asset="${base_name}-${version}-android-arm64.apk"
    bundle_name=""
    if [[ -z "${ANDROID_HOME:-}" && -z "${ANDROID_SDK_ROOT:-}" ]]; then
      echo "ANDROID_HOME or ANDROID_SDK_ROOT is required for Android export" >&2
      exit 1
    fi
    ;;
  *)
    echo "Unsupported target: $target" >&2
    exit 1
    ;;
esac

output_path="$export_dir/$primary_asset"
if [[ "$platform" == "android" ]]; then
  godot --headless --path "$repo_root" --install-android-build-template --export-release "$preset" "$output_path"
else
  godot --headless --path "$repo_root" --export-release "$preset" "$output_path"
fi
test -f "$output_path"

if [[ "$platform" == "android" ]]; then
  require_commands apksigner zipalign
  : "${ANDROID_SIGNING_KEYSTORE:?missing Android signing keystore path}"
  : "${ANDROID_SIGNING_KEYSTORE_PASSWORD:?missing Android signing keystore password}"
  : "${ANDROID_SIGNING_KEY_ALIAS:?missing Android signing key alias}"
  : "${ANDROID_SIGNING_KEY_PASSWORD:?missing Android signing key password}"

  unsigned_path="${output_path%.apk}-unsigned.apk"
  aligned_path="${output_path%.apk}-aligned.apk"
  mv "$output_path" "$unsigned_path"
  zipalign -p -f 4 "$unsigned_path" "$aligned_path"
  apksigner sign \
    --ks "$ANDROID_SIGNING_KEYSTORE" \
    --ks-pass env:ANDROID_SIGNING_KEYSTORE_PASSWORD \
    --ks-key-alias "$ANDROID_SIGNING_KEY_ALIAS" \
    --key-pass env:ANDROID_SIGNING_KEY_PASSWORD \
    --out "$output_path" \
    "$aligned_path"
  apksigner verify --verbose "$output_path" >/dev/null
  cp "$output_path" "$assets_dir/"
  printf '%s\n' "$assets_dir"
  exit 0
fi

bundle_dir="$package_parent/$bundle_name"
mkdir -p "$bundle_dir"
cp "$output_path" "$bundle_dir/"

while IFS= read -r sidecar; do
  cp "$sidecar" "$bundle_dir/"
done < <(find "$export_dir" -maxdepth 1 -type f ! -name "$(basename "$output_path")" | sort)

(
  cd "$package_parent"
  rm -f "$assets_dir/${bundle_name}.zip"
  zip -qr "$assets_dir/${bundle_name}.zip" "$bundle_name"
)

printf '%s\n' "$assets_dir"
