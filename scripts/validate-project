#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

test -f project.godot
command -v godot >/dev/null
command -v jq >/dev/null

# CI-safe validation path:
# Orchestrator may crash during editor import on some Linux runners.
# Recovery mode skips the problematic editor-side initialization while
# still proving that the project opens in an editor build.
godot --editor --recovery-mode --headless --path "$repo_root" --quit >/dev/null

jq -e '.version and .godotVersion and .linuxPreset and .artifactBaseName' VERSION.json >/dev/null

printf 'validation-ok\n'
