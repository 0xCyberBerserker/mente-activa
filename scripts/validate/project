#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$repo_root"

test -f project.godot
command -v godot >/dev/null
command -v jq >/dev/null
command -v python3 >/dev/null

if grep -RInE '^(<<<<<<<|=======|>>>>>>>)' \
  --exclude-dir=.git \
  --exclude-dir=.godot \
  --exclude-dir=build \
  --exclude-dir=dist \
  --exclude-dir=ejecutar \
  .; then
  echo "conflict markers found" >&2
  exit 1
fi

if git ls-files | grep -E '^(scene/|script/|Escena/|addons/(kanban_tasks|script-ide|discord_social_sdk)/|build/|dist/|ejecutar/|kanban_tasks_data\.kanban$|.*\.(apk|exe|pck|zip|sha256)$)' >/dev/null; then
  echo "legacy paths, editor-only addons, or generated artifacts are tracked" >&2
  exit 1
fi

godot --editor --recovery-mode --headless --path "$repo_root" --quit >/dev/null
python3 "$repo_root/scripts/validate/activity-data"

jq -e '
  .version and
  .godotVersion and
  .artifactBaseName and
  .repository and
  .targets["linux-x86_64"].preset and
  .targets["linux-arm64"].preset and
  .targets["windows-x86_64"].preset and
  .targets["android-arm64"].preset
' VERSION.json >/dev/null

grep -q 'name="Linux/X11"' export_presets.cfg
grep -q 'name="Linux ARM64"' export_presets.cfg
grep -q 'name="Windows Desktop"' export_presets.cfg
grep -q 'name="Android"' export_presets.cfg

printf 'validation-ok\n'
